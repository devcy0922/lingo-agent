# LingoAgent Environment Configuration

# Service Host & Port
PORT=9095
HOST=0.0.0.0

# LLM Gateway Config
# M1 Max 및 맥미니 환경에 맞게 적절한 LiteLLM/vLLM 엔드포인트 주소를 입력합니다.
# 예: 프로젝트 서버를 경유하는 LiteLLM 주소 -> http://192.168.0.5:8000/v1
LLM_GATEWAY_URL=http://<YOUR_IP>:8000/v1
LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# Database Settings (데모 편의성을 위해 기본 SQLite 사용)
DATABASE_URL=sqlite:///./data/db.sqlite3

# Local Output Path (최종 승인된 i18n JSON 파일이 저장될 경로)
OUTPUT_DIR=./data/output
